# Database (pick one)
# PostgreSQL:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/content_studio
# MySQL:
# DATABASE_URL=mysql+pymysql://root:password@localhost:3306/content_studio
# Quick local testing (no DB server needed):
# DATABASE_URL=sqlite:///./content_studio.db

# Auth
SECRET_KEY=change-this-to-a-long-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# AI Provider: "openai" or "gemini"
AI_PROVIDER=openai

OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash
